  try{ return JSON.parse(localStorage.getItem('gc_orders')||'[]'); }catch(e){ return []; }
}
function saveOrders(orders){ localStorage.setItem('gc_orders', JSON.stringify(orders)); }

// ═══════════════════════════════════════
//  TABS
// ═══════════════════════════════════════
function showTab(name){
  document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));
  document.getElementById('content-'+name).classList.add('active');
  document.getElementById('tab-'+name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(el=>el.classList.remove('active'));
  if(name==='orders') renderOrders();
  if(name==='admin') renderAdminPanel();
}

// ═══════════════════════════════════════
//  BRANCH SELECT
// ═══════════════════════════════════════
function selectBranch(idx, btn){
  selectedBranch = idx;
  document.querySelectorAll('.branch-select-btn').forEach(b=>b.classList.remove('sel'));
  if(btn) btn.classList.add('sel');
  document.getElementById('orderingFrom').textContent = BRANCHES[idx].name;
  document.getElementById('cartBranchName').textContent = BRANCHES[idx].name;
  renderItems();
  renderBranches();
  notify('🏪 Switched to '+BRANCHES[idx].name, '✅');
}

// ═══════════════════════════════════════
//  ITEMS / MENU
// ═══════════════════════════════════════
function renderFilters(){
  const bar = document.getElementById('filterBar');
  bar.innerHTML = CATEGORIES.map(c=>
    `<button class="filter-pill ${c===activeFilter?'active':''}" onclick="filterItems('${c}')">${c}</button>`
  ).join('');
}

function filterItems(cat){
  activeFilter = cat;
  renderFilters();
  renderItems();
}

function renderItems(){
  const avail = getProductAvail(selectedBranch);
  const grid = document.getElementById('itemsGrid');
  const filtered = activeFilter==='All' ? ITEMS : ITEMS.filter(i=>i.cat===activeFilter);
  grid.innerHTML = filtered.map(item=>{
    const qty = cart[item.id]||0;
    const isAvail = avail[item.id]!==false;
    return `<div class="item-card" style="${!isAvail?'opacity:.55;':''}">
      <div class="item-img">
        ${item.emoji}
        ${item.popular?'<span class="item-badge">⭐ Popular</span>':''}
      </div>
      <div class="item-info">
        <div class="item-name">${item.name} ${item.veg?'<span style="color:#2E7D32;font-size:11px;">🟢</span>':''}</div>
        <div class="item-desc">${item.desc}</div>
        <div class="item-footer">
          <div class="item-price">₹${item.price} <small>/ ${item.unit}</small></div>
          ${!isAvail ? '<span style="font-size:12px;color:#C62828;font-weight:600;">Out of Stock</span>' :
          qty===0 ?
            `<button class="add-btn" onclick="addToCart(${item.id})">+</button>` :
            `<div class="qty-control">
              <button class="qty-btn" onclick="changeQty(${item.id},-1)">−</button>
              <span class="qty-num">${qty}</span>
              <button class="qty-btn" onclick="changeQty(${item.id},1)">+</button>
            </div>`
          }
        </div>
      </div>
    </div>`;
  }).join('');
}

function addToCart(id){
  cart[id] = (cart[id]||0)+1;
  saveCart(); updateCartCount(); renderItems(); renderCartSidebar();
}
function changeQty(id, delta){
  cart[id] = Math.max(0, (cart[id]||0)+delta);
  if(cart[id]===0) delete cart[id];
  saveCart(); updateCartCount(); renderItems(); renderCartSidebar();
}
function updateCartCount(){
  const total = Object.values(cart).reduce((s,v)=>s+v,0);
  document.getElementById('cartCount').textContent = total;
}

// ═══════════════════════════════════════
//  CART
// ═══════════════════════════════════════
function toggleCart(){
  const overlay = document.getElementById('cartOverlay');
  const sidebar = document.getElementById('cartSidebar');
  overlay.classList.toggle('open');
  sidebar.classList.toggle('open');
  renderCartSidebar();
}

function renderCartSidebar(){
  const container = document.getElementById('cartItems');
  const footer = document.getElementById('cartFooter');
  const keys = Object.keys(cart).map(Number).filter(id=>cart[id]>0);
  if(keys.length===0){
    container.innerHTML = `<div class="cart-empty"><div class="empty-icon">🛒</div><p>Your cart is empty.<br/>Add some delicious sweets!</p></div>`;
    footer.style.display='none'; return;
  }
  let subtotal = 0;
  container.innerHTML = keys.map(id=>{
    const item = ITEMS.find(i=>i.id===id);
    const qty = cart[id];
    const lineTotal = item.price * qty;
    subtotal += lineTotal;
    return `<div class="cart-item">
      <div class="cart-item-icon">${item.emoji}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${item.name}</div>
        <div class="cart-item-price">₹${item.price} × ${qty} = ₹${lineTotal}</div>
      </div>
      <div class="cart-item-qty">
        <button class="qty-btn" onclick="changeQty(${id},-1)">−</button>
        <span class="qty-num">${qty}</span>
        <button class="qty-btn" onclick="changeQty(${id},1)">+</button>
      </div>
    </div>`;
  }).join('');
  const delivery = subtotal >= 500 ? 0 : 30;
  document.getElementById('cartSubtotal').textContent = '₹'+subtotal;
  document.getElementById('cartDelivery').textContent = delivery===0?'FREE':'₹'+delivery;
  document.getElementById('cartTotal').textContent = '₹'+(subtotal+delivery);
  footer.style.display='block';
}

// ═══════════════════════════════════════
//  CHECKOUT / ORDER
// ═══════════════════════════════════════
function openCheckout(){
  const keys = Object.keys(cart).map(Number).filter(id=>cart[id]>0);
  if(keys.length===0){ notify('Cart is empty!','❌'); return; }
  // Build summary
  let subtotal = 0;
  let summaryHTML = keys.map(id=>{
    const item = ITEMS.find(i=>i.id===id);
    const qty = cart[id];
    const lt = item.price*qty; subtotal+=lt;
    return `<div><span>${item.name} ×${qty}</span><span>₹${lt}</span></div>`;
  }).join('');
  const delivery = subtotal>=500?0:30;
  summaryHTML += `<div class="total-line"><span>Total</span><span>₹${subtotal+delivery}</span></div>`;
  document.getElementById('modalSummary').innerHTML = summaryHTML;
  document.getElementById('orderBranchSel').value = selectedBranch;
  document.getElementById('orderModal').classList.add('open');
}

function closeModal(){
  document.getElementById('orderModal').classList.remove('open');
}

function confirmOrder(){
  const name = document.getElementById('custName').value.trim();
  const phone = document.getElementById('custPhone').value.trim();
  const addr = document.getElementById('custAddr').value.trim();
  const branchIdx = parseInt(document.getElementById('orderBranchSel').value);
  if(!name){ notify('Please enter your name','❌'); return; }
  if(!phone){ notify('Please enter phone number','❌'); return; }
  if(!addr){ notify('Please enter delivery address','❌'); return; }

  const keys = Object.keys(cart).map(Number).filter(id=>cart[id]>0);
  let subtotal = 0;
  const items = keys.map(id=>{
    const item = ITEMS.find(i=>i.id===id);
    const qty = cart[id]; subtotal+=item.price*qty;
    return { name:item.name, qty, price:item.price, total:item.price*qty };
  });
  const delivery = subtotal>=500?0:30;
  const orderId = 'GC-'+Date.now().toString().slice(-6);
  const order = {
    id:orderId, name, phone, addr,
    branch: BRANCHES[branchIdx].name,
    items, subtotal, delivery, total:subtotal+delivery,
    date: new Date().toLocaleString('en-IN'),
    status:'Confirmed'
  };
  const orders = getOrders();
  orders.unshift(order);
  saveOrders(orders);
  lastOrderId = orderId;
  lastOrderCustomer = { name, phone, branch: BRANCHES[branchIdx].name, total: subtotal+delivery };
  cart = {};
  saveCart(); updateCartCount(); renderItems(); renderCartSidebar();
  closeModal();
  document.getElementById('cartOverlay').classList.remove('open');
  document.getElementById('cartSidebar').classList.remove('open');
  document.getElementById('successMsg').textContent = `Order #${orderId} placed for ${BRANCHES[branchIdx].name}. Total: ₹${subtotal+delivery}. We'll call you at ${phone}!`;
  document.getElementById('successModal').classList.add('open');
  notify('Order placed! 🎉','✅');
}

function closeSuccess(){
  document.getElementById('successModal').classList.remove('open');
}

function trackOnWA(){
  const c = lastOrderCustomer;
  if(!c) return;
  const msg = encodeURIComponent(`Hello Gaurav Confectionery! I placed order #${lastOrderId} for ₹${c.total} at ${c.branch}. Please confirm my order. – ${c.name}`);
  window.open('https://wa.me/'+WHATSAPP+'?text='+msg,'_blank');
  closeSuccess();
}

function orderViaWhatsApp(){
  const keys = Object.keys(cart).map(Number).filter(id=>cart[id]>0);
  if(keys.length===0){ notify('Cart is empty!','❌'); return; }
  let subtotal=0;
  let lines = keys.map(id=>{
    const item = ITEMS.find(i=>i.id===id);
    const qty = cart[id]; subtotal+=item.price*qty;
    return `• ${item.name} ×${qty} = ₹${item.price*qty}`;
  });
  const delivery = subtotal>=500?0:30;
  const msg = `Hello Gaurav Confectionery!\n\nI'd like to order from *${BRANCHES[selectedBranch].name}*:\n\n${lines.join('\n')}\n\nSubtotal: ₹${subtotal}\nDelivery: ${delivery===0?'FREE':'₹'+delivery}\n*Total: ₹${subtotal+delivery}*\n\nPlease confirm!`;
  window.open('https://wa.me/'+WHATSAPP+'?text='+encodeURIComponent(msg),'_blank');
}

// ═══════════════════════════════════════
//  BRANCHES RENDER
// ═══════════════════════════════════════
function renderBranches(){
  const grid = document.getElementById('branchesGrid');
  grid.innerHTML = BRANCHES.map(b=>`
    <div class="branch-card ${b.id===selectedBranch?'selected':''}" onclick="selectBranchAndOrder(${b.id})">
      <div class="branch-num">${b.id+1}</div>
      <div class="branch-name">${b.icon} ${b.name}</div>
      <div class="branch-addr">📍 ${b.addr}</div>
      <span class="branch-tag ${b.tag}">${b.tagLabel}</span>
      <div class="branch-hours">⏰ <strong>Hours:</strong> ${b.hours}</div>
      <div style="font-size:12px;color:var(--muted);margin-top:4px;">📞 ${b.phone}</div>
      <button class="sel-branch-btn" onclick="event.stopPropagation();selectBranchAndOrder(${b.id})">
        ${b.id===selectedBranch?'✅ Currently Selected':'Order from this Branch'}
      </button>
    </div>`).join('');
}

function selectBranchAndOrder(idx){
  selectedBranch = idx;
  document.querySelectorAll('.branch-select-btn').forEach((b,i)=>{ b.classList.toggle('sel',i===idx); });
  document.getElementById('orderingFrom').textContent = BRANCHES[idx].name;
  document.getElementById('cartBranchName').textContent = BRANCHES[idx].name;
  renderBranches(); renderItems();
  notify('Switched to '+BRANCHES[idx].name,'🏪');
}

// ═══════════════════════════════════════
//  ORDERS
// ═══════════════════════════════════════
function renderOrders(){
  const orders = getOrders();
  const container = document.getElementById('ordersContainer');
  if(orders.length===0){
    container.innerHTML = `<div class="no-orders">📭 No orders yet. Place your first order!</div>`; return;
  }
  container.innerHTML = orders.map(o=>`
    <div class="order-item-row">
      <div class="order-top">
        <span class="order-id">#${o.id} · ${o.date}</span>
        <span class="order-status ${o.status==='Confirmed'?'confirmed':'pending'}">${o.status}</span>
        <span class="order-total">₹${o.total}</span>
      </div>
      <div style="font-size:13px;margin-top:6px;"><strong>${o.name}</strong> · ${o.phone} · ${o.branch}</div>
      <div class="order-items-list">${o.items.map(i=>`${i.name} ×${i.qty}`).join(', ')}</div>
      <div style="font-size:12px;color:var(--muted);margin-top:4px;">📍 ${o.addr}</div>
    </div>`).join('');
}

function clearOrders(){
  if(confirm('Clear all order history?')){ localStorage.removeItem('gc_orders'); renderOrders(); }
}

// ═══════════════════════════════════════
//  ADMIN
// ═══════════════════════════════════════
function checkAdmin(){
  const pwd = document.getElementById('adminPwdInput').value;
  if(pwd==='admin123'){
    adminUnlocked = true;
    document.getElementById('adminGate').style.display='none';
    document.getElementById('adminPanel').style.display='block';
    renderAdminPanel();
  } else {
    document.getElementById('adminErr').style.display='block';
  }
}
function lockAdmin(){
  adminUnlocked = false;
  document.getElementById('adminGate').style.display='block';
  document.getElementById('adminPanel').style.display='none';
  document.getElementById('adminPwdInput').value='';
  document.getElementById('adminErr').style.display='none';
}

function selectStockBranch(idx){
  stockBranchIdx = idx;
  document.querySelectorAll('[id^=stockBranchBtn]').forEach((b,i)=>b.classList.toggle('active',i===idx));
  renderAdminPanel();
}

function renderAdminPanel(){
  if(!adminUnlocked) return;
  const stock = getStock(stockBranchIdx);
  // Summary
  const total = RAW_MATERIALS.length;
  let low=0, out=0;
  RAW_MATERIALS.forEach(m=>{ if(stock[m.id]===0) out++; else if(stock[m.id]<m.minQty) low++; });
  document.getElementById('stockSummary').innerHTML = `
    <div class="stock-stat"><strong>${total}</strong><span>Total Materials</span></div>
    <div class="stock-stat"><strong>${total-low-out}</strong><span>Well Stocked</span></div>
    <div class="stock-stat warn"><strong>${low}</strong><span>Low Stock</span></div>
    <div class="stock-stat danger"><strong>${out}</strong><span>Out of Stock</span></div>
    <div class="stock-stat"><strong>${BRANCHES[stockBranchIdx].name}</strong><span>Branch</span></div>
  `;
  // Material dropdown
  const sel = document.getElementById('stockMaterial');
  sel.innerHTML = '<option value="">Select Material</option>'+RAW_MATERIALS.map(m=>`<option value="${m.id}">${m.name}</option>`).join('');
  // Table
  const tbody = document.getElementById('stockTableBody');
  const maxQty = Math.max(...RAW_MATERIALS.map(m=>stock[m.id]||0), 1);
  tbody.innerHTML = RAW_MATERIALS.map(m=>{
    const qty = stock[m.id]||0;
    const pct = Math.min(100, Math.round(qty/Math.max(m.minQty*3,1)*100));
    const level = qty===0?'low':qty<m.minQty?'med':'high';
    const status = qty===0?'out':qty<m.minQty?'low':'ok';
    const statusLabel = qty===0?'Out of Stock':qty<m.minQty?'Low Stock':'In Stock';
    return `<tr>
      <td><strong>${m.name}</strong></td>
      <td>
        <div class="stock-level">
          <span style="min-width:50px;font-weight:600;color:${qty===0?'#C62828':qty<m.minQty?'#E65100':'#2E7D32'}">${qty}</span>
          <div class="stock-bar-wrap"><div class="stock-bar ${level}" style="width:${pct}%"></div></div>
        </div>
      </td>
      <td>${m.unit}</td>
      <td>${m.minQty}</td>
      <td><span class="status-pill ${status}">${statusLabel}</span></td>
      <td>
        <div class="stock-action-btns">
          <button class="s-btn plus" onclick="quickStock('${m.id}',10)">+10</button>
          <button class="s-btn plus" onclick="quickStock('${m.id}',50)">+50</button>
          <button class="s-btn minus" onclick="quickStock('${m.id}',-10)">-10</button>
        </div>
      </td>
    </tr>`;
  }).join('');
  // Product availability
  renderProductAvail();
}

function quickStock(matId, delta){
  const stock = getStock(stockBranchIdx);
  stock[matId] = Math.max(0, (stock[matId]||0)+delta);
  saveStock(stockBranchIdx, stock);
  renderAdminPanel();
  notify((delta>0?'Added ':'Reduced ')+Math.abs(delta)+' units of '+RAW_MATERIALS.find(m=>m.id===matId).name,'📦');
}

function updateStock(){
  const matId = document.getElementById('stockMaterial').value;
  const qty = parseFloat(document.getElementById('stockQty').value);
  const action = document.getElementById('stockAction').value;
  if(!matId){ notify('Please select a material','❌'); return; }
  if(isNaN(qty)||qty<0){ notify('Please enter valid quantity','❌'); return; }
  const stock = getStock(stockBranchIdx);
  if(action==='add') stock[matId] = (stock[matId]||0)+qty;
  else if(action==='set') stock[matId] = qty;
  else if(action==='reduce') stock[matId] = Math.max(0,(stock[matId]||0)-qty);
  saveStock(stockBranchIdx, stock);
  renderAdminPanel();
  const mat = RAW_MATERIALS.find(m=>m.id===matId);
  notify(`${mat.name} updated to ${stock[matId]} ${mat.unit}`,'✅');
  document.getElementById('stockQty').value='';
}

function renderProductAvail(){
  const avail = getProductAvail(stockBranchIdx);
  const grid = document.getElementById('productStockGrid');
  grid.innerHTML = ITEMS.map(item=>{
    const isAvail = avail[item.id]!==false;
    return `<div style="background:var(--lightcream);border:1.5px solid var(--border);border-radius:12px;padding:12px;display:flex;align-items:center;justify-content:space-between;gap:8px;">
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="font-size:22px;">${item.emoji}</span>
        <div>
          <div style="font-size:13px;font-weight:600;color:var(--darkbrown);">${item.name}</div>
          <div style="font-size:11px;color:var(--muted);">₹${item.price}/${item.unit}</div>
        </div>
      </div>
      <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
        <input type="checkbox" ${isAvail?'checked':''} onchange="toggleProductAvail(${item.id},this.checked)" style="width:18px;height:18px;accent-color:var(--saffron);cursor:pointer;"/>
        <span style="font-size:12px;color:${isAvail?'#2E7D32':'#C62828'};font-weight:600;">${isAvail?'Available':'Unavailable'}</span>
      </label>
    </div>`;
  }).join('');
}

function toggleProductAvail(itemId, checked){
  const avail = getProductAvail(stockBranchIdx);
  avail[itemId] = checked;
  saveProductAvail(stockBranchIdx, avail);
  renderItems();
  const item = ITEMS.find(i=>i.id===itemId);
  notify(`${item.name} marked as ${checked?'Available':'Unavailable'}`,'🍬');
}

// ═══════════════════════════════════════
//  NOTIFICATION
// ═══════════════════════════════════════
let notifTimer;
function notify(msg, icon='✅'){
  clearTimeout(notifTimer);
  document.getElementById('notifMsg').textContent = msg;
  document.querySelector('.n-icon').textContent = icon+' ';
  const el = document.getElementById('notification');
  el.classList.add('show');
  notifTimer = setTimeout(()=>el.classList.remove('show'), 3000);
}

// ═══════════════════════════════════════
//  INIT
// ═══════════════════════════════════════
loadState();
renderFilters();
renderItems();
renderBranches();
updateCartCount();
</script>
