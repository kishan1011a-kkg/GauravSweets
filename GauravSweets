<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Gaurav Confectionery – Rajendra Nagar, Nawada</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@700&family=Playfair+Display:wght@400;600;700&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet"/>
<style>
:root{
  --saffron:#D4500A;
  --gold:#E8981C;
  --cream:#FFF8F0;
  --maroon:#7A1B1B;
  --darkbrown:#2C1208;
  --lightcream:#FEF3E6;
  --white:#FFFFFF;
  --success:#2E7D32;
  --warning:#E65100;
  --danger:#C62828;
  --text:#2C1208;
  --muted:#7A5C3D;
  --border:#E8D5B7;
  --shadow:0 4px 20px rgba(44,18,8,0.12);
  --shadow-lg:0 8px 40px rgba(44,18,8,0.18);
}
*{margin:0;padding:0;box-sizing:border-box;}
body{font-family:'Poppins',sans-serif;background:var(--cream);color:var(--text);min-height:100vh;}
h1,h2,h3{font-family:'Playfair Display',serif;}

/* SCROLLBAR */
::-webkit-scrollbar{width:6px;}
::-webkit-scrollbar-track{background:var(--lightcream);}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px;}

/* TOP BANNER */
.top-banner{background:var(--maroon);color:#FFE8C0;text-align:center;padding:7px 16px;font-size:13px;letter-spacing:.5px;}
.top-banner span{color:var(--gold);}

/* NAVBAR */
.navbar{
  background:var(--white);
  border-bottom:3px solid var(--gold);
  position:sticky;top:0;z-index:1000;
  box-shadow:var(--shadow);
}
.nav-inner{max-width:1200px;margin:0 auto;padding:12px 20px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;}
.logo{display:flex;align-items:center;gap:12px;}
.logo-icon{width:50px;height:50px;background:linear-gradient(135deg,var(--saffron),var(--gold));border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:22px;box-shadow:0 3px 10px rgba(212,80,10,.35);}
.logo-text h1{font-family:'Cinzel Decorative',serif;font-size:18px;color:var(--saffron);line-height:1.1;}
.logo-text p{font-size:11px;color:var(--muted);font-family:'Poppins',sans-serif;}
.nav-links{display:flex;align-items:center;gap:6px;flex-wrap:wrap;}
.nav-btn{background:none;border:none;cursor:pointer;font-family:'Poppins',sans-serif;font-size:13.5px;font-weight:500;color:var(--text);padding:7px 14px;border-radius:8px;transition:.2s;}
.nav-btn:hover,.nav-btn.active{background:var(--lightcream);color:var(--saffron);}
.nav-btn.admin-btn{color:var(--maroon);border:1.5px solid var(--maroon);}
.nav-btn.admin-btn:hover{background:var(--maroon);color:#fff;}
.cart-btn{background:var(--saffron);color:#fff;border:none;padding:9px 18px;border-radius:10px;cursor:pointer;font-family:'Poppins',sans-serif;font-size:14px;font-weight:600;display:flex;align-items:center;gap:8px;transition:.2s;box-shadow:0 3px 10px rgba(212,80,10,.3);}
.cart-btn:hover{background:var(--maroon);}
.cart-count{background:#fff;color:var(--saffron);border-radius:50%;width:22px;height:22px;display:inline-flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;}

/* HERO */
.hero{
  background:linear-gradient(135deg,var(--darkbrown) 0%,var(--maroon) 50%,#8B2500 100%);
  color:#fff;
  padding:60px 20px;
  text-align:center;
  position:relative;
  overflow:hidden;
}
.hero::before{
  content:'';position:absolute;top:0;left:0;right:0;bottom:0;
  background-image:repeating-linear-gradient(45deg,rgba(232,152,28,.07) 0,rgba(232,152,28,.07) 1px,transparent 0,transparent 50%);
  background-size:20px 20px;
}
.hero-inner{position:relative;max-width:700px;margin:0 auto;}
.hero-badge{display:inline-block;background:rgba(232,152,28,.2);border:1.5px solid var(--gold);color:var(--gold);padding:5px 18px;border-radius:20px;font-size:12px;font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:18px;}
.hero h2{font-family:'Cinzel Decorative',serif;font-size:clamp(24px,5vw,46px);color:#FFE8C0;margin-bottom:10px;text-shadow:0 2px 10px rgba(0,0,0,.4);}
.hero p{font-size:15px;color:rgba(255,232,192,.8);margin-bottom:24px;line-height:1.7;}
.hero-branch-btns{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;}
.branch-select-btn{background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.3);color:#fff;padding:10px 20px;border-radius:10px;cursor:pointer;font-size:13.5px;font-family:'Poppins',sans-serif;transition:.2s;}
.branch-select-btn:hover,.branch-select-btn.sel{background:var(--gold);border-color:var(--gold);color:var(--darkbrown);font-weight:600;}
.hero-stats{display:flex;gap:30px;justify-content:center;margin-top:28px;flex-wrap:wrap;}
.hero-stat{text-align:center;}
.hero-stat strong{display:block;font-size:22px;color:var(--gold);font-family:'Playfair Display',serif;}
.hero-stat span{font-size:12px;color:rgba(255,232,192,.7);}

/* MAIN */
.main-content{max-width:1200px;margin:0 auto;padding:30px 20px 100px;}

/* SECTION HEADER */
.section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:10px;}
.section-title{font-size:26px;color:var(--maroon);}
.section-title span{color:var(--saffron);}
.section-divider{height:3px;width:60px;background:linear-gradient(90deg,var(--saffron),var(--gold));border-radius:2px;margin:6px 0 0;}

/* FILTER BAR */
.filter-bar{display:flex;gap:8px;margin-bottom:22px;flex-wrap:wrap;}
.filter-pill{border:1.5px solid var(--border);background:var(--white);color:var(--muted);padding:7px 16px;border-radius:20px;cursor:pointer;font-size:13px;font-family:'Poppins',sans-serif;transition:.2s;}
.filter-pill:hover,.filter-pill.active{background:var(--saffron);border-color:var(--saffron);color:#fff;}

/* ITEMS GRID */
.items-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:20px;}
.item-card{
  background:var(--white);
  border:1.5px solid var(--border);
  border-radius:16px;
  overflow:hidden;
  transition:.25s;
  box-shadow:0 2px 10px rgba(44,18,8,.07);
}
.item-card:hover{transform:translateY(-4px);box-shadow:var(--shadow-lg);}
.item-img{
  height:160px;
  display:flex;align-items:center;justify-content:center;
  font-size:64px;
  background:linear-gradient(135deg,var(--lightcream),#FFF0D6);
  position:relative;
}
.item-badge{
  position:absolute;top:10px;right:10px;
  background:var(--gold);color:var(--darkbrown);
  font-size:11px;font-weight:700;padding:3px 9px;border-radius:10px;
}
.item-badge.veg{background:#E8F5E9;color:#2E7D32;border:1px solid #A5D6A7;}
.item-info{padding:14px;}
.item-name{font-size:15px;font-weight:600;color:var(--darkbrown);margin-bottom:3px;}
.item-desc{font-size:12px;color:var(--muted);margin-bottom:10px;line-height:1.5;}
.item-footer{display:flex;align-items:center;justify-content:space-between;}
.item-price{font-size:17px;font-weight:700;color:var(--saffron);}
.item-price small{font-size:11px;color:var(--muted);font-weight:400;}
.add-btn{background:var(--saffron);color:#fff;border:none;width:34px;height:34px;border-radius:10px;cursor:pointer;font-size:20px;display:flex;align-items:center;justify-content:center;transition:.2s;font-family:'Poppins',sans-serif;}
.add-btn:hover{background:var(--maroon);}
.qty-control{display:flex;align-items:center;gap:6px;}
.qty-btn{background:var(--lightcream);border:1.5px solid var(--border);width:28px;height:28px;border-radius:8px;cursor:pointer;font-size:16px;font-weight:700;color:var(--saffron);font-family:'Poppins',sans-serif;transition:.15s;}
.qty-btn:hover{background:var(--saffron);color:#fff;border-color:var(--saffron);}
.qty-num{font-size:14px;font-weight:600;min-width:20px;text-align:center;color:var(--darkbrown);}

/* CART SIDEBAR */
.cart-overlay{position:fixed;inset:0;background:rgba(44,18,8,.45);z-index:2000;opacity:0;pointer-events:none;transition:.3s;}
.cart-overlay.open{opacity:1;pointer-events:all;}
.cart-sidebar{
  position:fixed;right:-420px;top:0;bottom:0;width:380px;max-width:95vw;
  background:var(--white);
  box-shadow:-5px 0 30px rgba(44,18,8,.2);
  z-index:2001;
  transition:.35s cubic-bezier(.4,0,.2,1);
  display:flex;flex-direction:column;
}
.cart-sidebar.open{right:0;}
.cart-header{background:var(--maroon);color:#fff;padding:18px 20px;display:flex;justify-content:space-between;align-items:center;}
.cart-header h3{font-size:18px;}
.cart-close{background:rgba(255,255,255,.2);border:none;color:#fff;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:18px;display:flex;align-items:center;justify-content:center;}
.cart-branch-info{background:var(--lightcream);padding:10px 20px;font-size:13px;color:var(--muted);border-bottom:1px solid var(--border);}
.cart-branch-info strong{color:var(--saffron);}
.cart-items{flex:1;overflow-y:auto;padding:14px 20px;}
.cart-empty{text-align:center;padding:50px 20px;color:var(--muted);}
.cart-empty .empty-icon{font-size:50px;margin-bottom:12px;}
.cart-item{display:flex;gap:10px;align-items:center;padding:12px 0;border-bottom:1px solid var(--border);}
.cart-item-icon{font-size:28px;width:42px;height:42px;background:var(--lightcream);border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.cart-item-info{flex:1;}
.cart-item-name{font-size:14px;font-weight:600;color:var(--darkbrown);}
.cart-item-price{font-size:13px;color:var(--muted);}
.cart-item-qty{display:flex;align-items:center;gap:6px;}
.cart-footer{padding:16px 20px;border-top:2px solid var(--border);}
.cart-total-row{display:flex;justify-content:space-between;font-size:14px;color:var(--muted);margin-bottom:6px;}
.cart-total-row.big{font-size:18px;font-weight:700;color:var(--darkbrown);margin-bottom:14px;}
.checkout-btn{width:100%;background:linear-gradient(135deg,var(--saffron),var(--gold));color:#fff;border:none;padding:14px;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Poppins',sans-serif;transition:.2s;box-shadow:0 4px 15px rgba(212,80,10,.3);}
.checkout-btn:hover{background:linear-gradient(135deg,var(--maroon),var(--saffron));}
.wa-order-btn{width:100%;background:#25D366;color:#fff;border:none;padding:11px;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;font-family:'Poppins',sans-serif;margin-top:8px;display:flex;align-items:center;justify-content:center;gap:8px;}
.wa-order-btn:hover{background:#128C7E;}

/* BRANCHES */
.branches-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px;}
.branch-card{background:var(--white);border:1.5px solid var(--border);border-radius:16px;padding:24px;box-shadow:0 2px 10px rgba(44,18,8,.07);transition:.2s;cursor:pointer;}
.branch-card:hover{border-color:var(--saffron);box-shadow:var(--shadow);}
.branch-card.selected{border:2.5px solid var(--saffron);background:linear-gradient(135deg,#FFF8F0,#FEF0D8);}
.branch-num{width:40px;height:40px;background:var(--saffron);color:#fff;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:700;margin-bottom:14px;}
.branch-card.selected .branch-num{background:var(--maroon);}
.branch-name{font-size:17px;font-weight:700;color:var(--darkbrown);margin-bottom:4px;}
.branch-addr{font-size:13px;color:var(--muted);margin-bottom:12px;line-height:1.5;}
.branch-tag{display:inline-block;padding:3px 12px;border-radius:10px;font-size:11px;font-weight:600;}
.branch-tag.open{background:#E8F5E9;color:#2E7D32;}
.branch-tag.main{background:#FFF3E0;color:#E65100;}
.branch-hours{font-size:12px;color:var(--muted);margin-top:8px;}
.branch-hours strong{color:var(--darkbrown);}
.sel-branch-btn{margin-top:14px;width:100%;background:var(--saffron);color:#fff;border:none;padding:10px;border-radius:10px;font-size:13.5px;font-weight:600;cursor:pointer;font-family:'Poppins',sans-serif;transition:.2s;}
.sel-branch-btn:hover{background:var(--maroon);}

/* STOCK MANAGEMENT */
.stock-panel{background:var(--white);border:1.5px solid var(--border);border-radius:16px;padding:24px;box-shadow:var(--shadow);}
.stock-summary{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:14px;margin-bottom:28px;}
.stock-stat{background:var(--lightcream);border-radius:12px;padding:16px;text-align:center;border:1px solid var(--border);}
.stock-stat strong{display:block;font-size:26px;font-family:'Playfair Display',serif;color:var(--saffron);}
.stock-stat span{font-size:12px;color:var(--muted);}
.stock-stat.warn strong{color:var(--warning);}
.stock-stat.danger strong{color:var(--danger);}
.stock-controls{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap;align-items:center;}
.stock-controls input,.stock-controls select{border:1.5px solid var(--border);background:var(--white);padding:9px 14px;border-radius:10px;font-size:13.5px;font-family:'Poppins',sans-serif;color:var(--text);outline:none;}
.stock-controls input:focus,.stock-controls select:focus{border-color:var(--saffron);}
.add-stock-btn{background:var(--success);color:#fff;border:none;padding:10px 20px;border-radius:10px;cursor:pointer;font-size:13.5px;font-weight:600;font-family:'Poppins',sans-serif;white-space:nowrap;}
.stock-table-wrap{overflow-x:auto;}
.stock-table{width:100%;border-collapse:collapse;font-size:14px;}
.stock-table th{background:var(--darkbrown);color:#FFE8C0;padding:11px 14px;text-align:left;font-family:'Playfair Display',serif;font-size:14px;}
.stock-table th:first-child{border-radius:8px 0 0 0;}
.stock-table th:last-child{border-radius:0 8px 0 0;}
.stock-table td{padding:11px 14px;border-bottom:1px solid var(--border);}
.stock-table tr:hover td{background:var(--lightcream);}
.stock-level{display:flex;align-items:center;gap:10px;}
.stock-bar-wrap{flex:1;background:#F0E8D8;border-radius:4px;height:8px;min-width:80px;}
.stock-bar{height:8px;border-radius:4px;transition:.4s;}
.stock-bar.high{background:linear-gradient(90deg,#4CAF50,#81C784);}
.stock-bar.med{background:linear-gradient(90deg,var(--gold),#FFB74D);}
.stock-bar.low{background:linear-gradient(90deg,var(--danger),#EF9A9A);}
.status-pill{padding:3px 10px;border-radius:10px;font-size:11px;font-weight:700;}
.status-pill.ok{background:#E8F5E9;color:#2E7D32;}
.status-pill.low{background:#FFF3E0;color:#E65100;}
.status-pill.out{background:#FFEBEE;color:#C62828;}
.stock-action-btns{display:flex;gap:6px;}
.s-btn{border:1.5px solid var(--border);background:var(--white);padding:5px 10px;border-radius:8px;cursor:pointer;font-size:12px;font-family:'Poppins',sans-serif;transition:.15s;}
.s-btn.plus{border-color:#4CAF50;color:#2E7D32;}
.s-btn.plus:hover{background:#4CAF50;color:#fff;}
.s-btn.minus{border-color:var(--danger);color:var(--danger);}
.s-btn.minus:hover{background:var(--danger);color:#fff;}

/* ORDER MODAL */
.modal-overlay{position:fixed;inset:0;background:rgba(44,18,8,.55);z-index:3000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;pointer-events:none;transition:.3s;}
.modal-overlay.open{opacity:1;pointer-events:all;}
.modal-box{background:var(--white);border-radius:20px;max-width:480px;width:100%;box-shadow:var(--shadow-lg);overflow:hidden;transform:scale(.95);transition:.3s;}
.modal-overlay.open .modal-box{transform:scale(1);}
.modal-header{background:linear-gradient(135deg,var(--saffron),var(--gold));color:#fff;padding:20px 24px;display:flex;justify-content:space-between;align-items:center;}
.modal-header h3{font-size:20px;}
.modal-close{background:rgba(255,255,255,.2);border:none;color:#fff;width:32px;height:32px;border-radius:8px;cursor:pointer;font-size:18px;font-family:'Poppins',sans-serif;}
.modal-body{padding:24px;}
.form-group{margin-bottom:16px;}
.form-group label{display:block;font-size:13px;font-weight:600;color:var(--muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px;}
.form-group input,.form-group select,.form-group textarea{width:100%;border:1.5px solid var(--border);background:var(--cream);padding:11px 14px;border-radius:10px;font-size:14px;font-family:'Poppins',sans-serif;color:var(--text);outline:none;transition:.2s;}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--saffron);background:#fff;}
.modal-order-summary{background:var(--lightcream);border-radius:12px;padding:14px;margin-bottom:16px;font-size:13px;}
.modal-order-summary div{display:flex;justify-content:space-between;padding:3px 0;}
.modal-order-summary .total-line{font-weight:700;font-size:15px;border-top:1px solid var(--border);padding-top:8px;margin-top:6px;}
.confirm-order-btn{width:100%;background:linear-gradient(135deg,var(--saffron),var(--gold));color:#fff;border:none;padding:14px;border-radius:12px;font-size:16px;font-weight:700;cursor:pointer;font-family:'Poppins',sans-serif;}
.confirm-order-btn:hover{opacity:.9;}

/* SUCCESS */
.success-modal{text-align:center;padding:40px 24px;}
.success-icon{font-size:64px;margin-bottom:16px;}
.success-modal h3{font-size:22px;color:var(--success);margin-bottom:8px;}
.success-modal p{font-size:14px;color:var(--muted);margin-bottom:24px;}
.success-wa-btn{background:#25D366;color:#fff;border:none;padding:13px 30px;border-radius:12px;font-size:15px;font-weight:700;cursor:pointer;font-family:'Poppins',sans-serif;display:inline-flex;align-items:center;gap:10px;}

/* ORDERS TABLE */
.orders-section{margin-top:30px;}
.order-item-row{background:var(--white);border:1.5px solid var(--border);border-radius:12px;padding:16px;margin-bottom:12px;}
.order-top{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px;}
.order-id{font-size:13px;font-weight:600;color:var(--muted);}
.order-total{font-size:16px;font-weight:700;color:var(--saffron);}
.order-status{padding:4px 12px;border-radius:10px;font-size:12px;font-weight:600;}
.order-status.pending{background:#FFF3E0;color:#E65100;}
.order-status.confirmed{background:#E8F5E9;color:#2E7D32;}
.order-items-list{margin-top:8px;font-size:13px;color:var(--muted);}
.no-orders{text-align:center;padding:30px;color:var(--muted);font-size:14px;}

/* TABS */
.tab-nav{display:flex;gap:6px;background:var(--lightcream);padding:6px;border-radius:14px;margin-bottom:28px;flex-wrap:wrap;}
.tab-btn{flex:1;min-width:80px;background:none;border:none;padding:10px 12px;border-radius:10px;cursor:pointer;font-family:'Poppins',sans-serif;font-size:13.5px;font-weight:500;color:var(--muted);transition:.2s;}
.tab-btn:hover{background:rgba(212,80,10,.08);color:var(--saffron);}
.tab-btn.active{background:var(--white);color:var(--saffron);box-shadow:0 2px 10px rgba(44,18,8,.1);font-weight:600;}
.tab-content{display:none;}
.tab-content.active{display:block;}

/* WHATSAPP FLOAT */
.wa-float{
  position:fixed;bottom:28px;right:28px;z-index:999;
  display:flex;flex-direction:column;align-items:flex-end;gap:10px;
}
.wa-float-tooltip{
  background:var(--darkbrown);color:#fff;
  padding:8px 14px;border-radius:10px;font-size:13px;font-weight:500;
  white-space:nowrap;opacity:0;transform:translateX(10px);
  transition:.2s;pointer-events:none;
}
.wa-float:hover .wa-float-tooltip{opacity:1;transform:translateX(0);}
.wa-float-btn{
  width:60px;height:60px;border-radius:50%;
  background:#25D366;
  display:flex;align-items:center;justify-content:center;
  box-shadow:0 4px 20px rgba(37,211,102,.45);
  cursor:pointer;transition:.2s;text-decoration:none;
}
.wa-float-btn:hover{background:#128C7E;transform:scale(1.08);}
.wa-float-btn svg{width:32px;height:32px;fill:#fff;}

/* NOTIFICATION */
.notification{
  position:fixed;top:80px;right:20px;z-index:5000;
  background:var(--darkbrown);color:#FFE8C0;
  padding:12px 20px;border-radius:12px;font-size:14px;
  box-shadow:var(--shadow-lg);
  transform:translateX(120%);transition:.3s;
  max-width:280px;
}
.notification.show{transform:translateX(0);}
.notification .n-icon{margin-right:8px;}

/* FOOTER */
footer{background:var(--darkbrown);color:#FFE8C0;padding:30px 20px;text-align:center;margin-top:0;}
footer h3{font-family:'Cinzel Decorative',serif;font-size:18px;color:var(--gold);margin-bottom:8px;}
footer p{font-size:13px;opacity:.8;line-height:1.8;}
footer .footer-links{display:flex;gap:20px;justify-content:center;margin:14px 0;flex-wrap:wrap;}
footer .footer-links a{color:var(--gold);text-decoration:none;font-size:13px;}
.footer-bottom{margin-top:20px;padding-top:14px;border-top:1px solid rgba(255,232,192,.15);font-size:12px;opacity:.6;}

/* Responsive */
@media(max-width:600px){
  .nav-links{display:none;}
  .hero h2{font-size:22px;}
